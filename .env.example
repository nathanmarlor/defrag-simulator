# Defrag Simulation Configuration
# Copy this file to .env and adjust values for your build

# Grid dimensions
GRID_COLS=16
GRID_ROWS=8

# Block character to use (Unicode full block)
BLOCK_CHAR='\u2588'

# Simulation speed (ms per update)
SIMULATION_SPEED=50

# Color palette (hex)
BG_COLOR=#0000AA
FG_COLOR=#FFFFFF
